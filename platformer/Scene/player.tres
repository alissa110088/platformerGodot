[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform float Intensity;



void fragment() {
	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(TEXTURE, UV);


	vec3 n_out4p0;
// ColorFunc:4
	{
		vec3 c = vec3(n_out3p0.xyz);
		float max1 = max(c.r, c.g);
		float max2 = max(max1, c.b);
		n_out4p0 = vec3(max2, max2, max2);
	}


// FloatParameter:6
	float n_out6p0 = Intensity;


// Mix:5
	vec3 n_out5p0 = mix(n_out4p0, vec3(n_out3p0.xyz), vec3(n_out6p0));


// Output:0
	COLOR.rgb = n_out5p0;


}
"
